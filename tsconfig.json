{
    "compilerOptions": {
        "module": "commonjs",
        "target": "ES2020",
        "lib": [
            "ES2020"
        ],
        "outDir": "dist",
        "rootDir": ".",
        "sourceMap": true,
        "strict": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "types": [
            "node"
        ]
    },
    "exclude": [
        "node_modules",
        ".vscode-test",
        "dist",
        "out"
    ]
}
