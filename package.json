{
  "name": "vscode-nupkg",
  "displayName": "NuGet NuPkg Viewer",
  "description": "Display all information from a NuPkg file",
  "version": "2.0.0",
  "publisher": "eridem",
  "keywords": [
    "nuget",
    "nupkg",
    "viewer",
    "manifest",
    "unzip"
  ],
  "author": {
    "name": "Miguel Ángel Domínguez Coloma",
    "url": "https://eridem.com"
  },
  "markdown": "github",
  "contributors": [],
  "license": "SEE LICENSE IN LICENSE.md",
  "homepage": "https://eridem.com/vscode-extensions/vscode-nupkg",
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Other"
  ],
  "bugs": {
    "url": "https://github.com/eridem/vscode-nupkg/issues",
    "email": "m@eridem.net"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/eridem/vscode-nupkg"
  },
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "nupkg",
        "aliases": [
          "NuPkg",
          "nupkg"
        ],
        "extensions": [
          ".nupkg"
        ]
      }
    ],
    "customEditors": [
      {
        "viewType": "nupkg.preview",
        "displayName": "NuPkg Preview",
        "selector": [
          {
            "filenamePattern": "*.nupkg"
          }
        ],
        "priority": "default"
      }
    ],
    "configuration": {
      "title": "NuGet NuPkg Viewer",
      "properties": {
        "nupkg.preview.defaultMode": {
          "type": "string",
          "enum": [
            "modern",
            "yaml"
          ],
          "enumDescriptions": [
            "Rendered HTML preview of the package.",
            "Raw YAML text (legacy view)."
          ],
          "default": "modern",
          "description": "Which view the NuPkg preview opens in by default."
        }
      }
    },
    "commands": [
      {
        "command": "extension.preview",
        "title": "Preview NuPkg contents",
        "icon": {
          "light": "./images/menu-light.svg",
          "dark": "./images/menu-dark.svg"
        },
        "category": "NuPkg"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "extension.preview",
          "alt": "extension.preview",
          "group": "navigation",
          "when": "resourceLangId == nupkg"
        }
      ],
      "explorer/context": [
        {
          "command": "extension.preview",
          "alt": "extension.preview",
          "group": "navigation",
          "when": "resourceLangId == nupkg"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run check-types && node esbuild.js --production",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch -p ./",
    "check-types": "tsc --noEmit -p ./",
    "lint": "eslint src",
    "test": "node --import tsx --test src/test/*.test.ts",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^26.1.1",
    "@types/vscode": "^1.125.0",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.9.5",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "adm-zip": "^0.5.18",
    "js-yaml": "^5.2.1",
    "smart-nupkg-metadata-reader": "^1.0.0"
  }
}
